# Runtime
ENV=local
PORT=8000

# Provider selection
# LLM_PROVIDER options: groq, google
# EMBEDDING_PROVIDER options: ollama, google
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=ollama

# API keys
# The current app startup validates that both keys are present.
GROQ_API_KEY=
GOOGLE_API_KEY=

# Optional alternative supported by the code:
# API_KEYS={"GROQ_API_KEY":"your_groq_api_key","GOOGLE_API_KEY":"your_google_api_key"}
